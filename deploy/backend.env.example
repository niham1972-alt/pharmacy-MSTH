# === Backend runtime env (copy to deploy/backend.env and fill in) ===============
# Auth + Database stay on Supabase cloud (managed). Only file STORAGE is on the VPS.

# Supabase Postgres — use the Session Pooler connection string (port 5432).
# Supabase → Project → Connect → "Session pooler".
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Supabase → Settings → API
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Supabase → Settings → API → "JWT Secret" (legacy). Needed for backend-issued
# impersonation tokens; also the fallback secret if IMPERSONATION_JWT_SECRET is unset.
SUPABASE_JWT_SECRET=<jwt-secret>

# A long random string (openssl rand -base64 48) — signs impersonation tokens.
IMPERSONATION_JWT_SECRET=<change-me-to-a-long-random-string>

# Same-origin via Nginx means CORS isn't exercised, but set your IP anyway.
CORS_ORIGINS=http://<VPS_PUBLIC_IP>

# Redis is optional; off by default (caches no-op gracefully).
REDIS_ENABLED=false

# Allow selling below zero stock? (mirrors the Settings toggle; false = safe default)
ALLOW_NEGATIVE_STOCK=false

# --- VPS file storage (defaults already set by docker-compose; override if needed) ---
# UPLOAD_DIR=/app/uploads
# PUBLIC_UPLOADS_BASE=/uploads
# MAX_UPLOAD_BYTES=5242880
