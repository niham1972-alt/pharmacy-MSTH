# === Frontend build args (copy to deploy/.env and fill in) ======================
# These are BAKED INTO the frontend bundle at build time (docker compose build).
# Change them → rebuild the `web` image.

# Same-origin: the SPA calls /api, which Nginx proxies to the backend. Leave as-is.
VITE_API_BASE_URL=/api

# Supabase (managed cloud) — Auth is still Supabase.
# Supabase → Settings → API.
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
