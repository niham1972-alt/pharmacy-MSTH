# --- Supabase Postgres ---
# From Supabase dashboard > Settings > Database > Connection string (use the pooled connection for the app).
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# --- Supabase Auth ---
SUPABASE_URL="https://your-project.supabase.co"
# Settings > API > JWT Secret (HS256 shared secret used to verify tokens in JwtAuthGuard).
SUPABASE_JWT_SECRET="replace-with-your-supabase-jwt-secret"
# Settings > API > service_role key (server-side only, never expose to the frontend).
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"

# --- Redis (optional; caching gracefully no-ops when disabled) ---
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# --- App ---
PORT=3000
CORS_ORIGINS="http://localhost:5173"

# --- Purchases (Module 3) business rules — belong to Settings (Module 18); env-overridable defaults ---
PO_COSTING_RULE=LATEST_COST            # LATEST_COST | WEIGHTED_AVERAGE | MANUAL_ONLY
PO_AUTO_APPROVE_THRESHOLD=50000        # POs at/under this grand total auto-approve on submit
PO_OVER_RECEIPT_TOLERANCE_PCT=0        # extra % receivable beyond ordered qty
PO_VARIANCE_WARN_PCT=10                # soft cost-variance warning threshold
PO_VARIANCE_BLOCK_PCT=50               # hard-block threshold requiring acknowledgement

# --- Sales / POS (Module 4) business rules — belong to Settings (Module 18) ---
POS_AUTO_DISCOUNT_PCT=5                 # discount % a cashier can apply without approval
ALLOW_NEGATIVE_STOCK=false             # permit selling below zero stock (backorder)
POS_VOID_WINDOW_DAYS=1                  # days a completed sale can be voided (else use Returns)
SESSION_VARIANCE_THRESHOLD=100         # cash variance beyond this flags a session for review
