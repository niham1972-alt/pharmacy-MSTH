# --- Supabase Postgres (REQUIRED) ---
# Use the SESSION POOLER connection string (Dashboard > Connect > Session pooler).
# The "direct" connection is IPv6-only and unreachable from most hosts incl.
# Railway — use the pooler. URL-encode special chars in the password (@ -> %40).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (REQUIRED) ---
SUPABASE_URL="https://your-project.supabase.co"
# Settings > API > service_role key (server-side ONLY — never expose to the frontend/browser bundle).
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-service-role-key"
# Token verification: new Supabase projects sign JWTs with ES256 and the guard
# fetches public keys from ${SUPABASE_URL}/auth/v1/.well-known/jwks.json automatically.
# SUPABASE_JWT_SECRET is OPTIONAL — only needed for legacy HS256-signed projects.
SUPABASE_JWT_SECRET=""
# Optional override if your JWKS lives at a non-default URL.
# SUPABASE_JWKS_URL=""

# --- Redis (optional; caching gracefully no-ops when disabled) ---
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# --- App ---
# PORT is assigned automatically by Railway; only set for local dev.
PORT=3000
# Comma-separated allowed frontend origins. In production include your Vercel URL,
# e.g. CORS_ORIGINS="https://your-app.vercel.app,http://localhost:5173"
CORS_ORIGINS="http://localhost:5173"

# Module 16: step-up (re-auth) challenge window in ms (default 120000 = 2 min).
STEP_UP_WINDOW_MS=120000

# --- Purchases (Module 3) business rules — belong to Settings (Module 18); env-overridable defaults ---
PO_COSTING_RULE=LATEST_COST            # LATEST_COST | WEIGHTED_AVERAGE | MANUAL_ONLY
PO_AUTO_APPROVE_THRESHOLD=50000        # POs at/under this grand total auto-approve on submit
PO_OVER_RECEIPT_TOLERANCE_PCT=0        # extra % receivable beyond ordered qty
PO_VARIANCE_WARN_PCT=10                # soft cost-variance warning threshold
PO_VARIANCE_BLOCK_PCT=50               # hard-block threshold requiring acknowledgement

# --- Sales / POS (Module 4) business rules — belong to Settings (Module 18) ---
POS_AUTO_DISCOUNT_PCT=5                 # discount % a cashier can apply without approval
ALLOW_NEGATIVE_STOCK=false             # permit selling below zero stock (backorder)
POS_VOID_WINDOW_DAYS=1                  # days a completed sale can be voided (else use Returns)
SESSION_VARIANCE_THRESHOLD=100         # cash variance beyond this flags a session for review

# Interactive-transaction budget (ms). Raise on high-latency DB links (e.g. remote Supabase pooler)
# or heavy multi-line sales. Defaults: maxWait 10000, timeout 30000.
PRISMA_TX_MAX_WAIT_MS=10000
PRISMA_TX_TIMEOUT_MS=30000

# Module 15: keyed HMAC secret for the audit-log tamper-evidence hash-chain.
# MUST be set to a strong random value in production and kept secret.
AUDIT_HASH_SECRET=change-me-to-a-strong-random-secret
