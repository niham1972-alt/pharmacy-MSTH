// Module 1: Dashboard — Prisma schema
// Dashboard-owned models are authoritative here.
// Cross-module models are STUBS: minimal shape needed for Dashboard queries to
// compile and run. They will be superseded by the authoritative schema when
// each module is built — reconcile via `prisma migrate` at that time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Dashboard-owned tables
// ---------------------------------------------------------------------------

model DashboardWidgetPreference {
  id         String   @id @default(uuid())
  userId     String
  pharmacyId String
  branchId   String?
  widgetKey  String // e.g. "kpi_cards", "sales_trend"
  isVisible  Boolean  @default(true)
  position   Int      @default(0)
  config     Json? // widget-specific settings e.g. default date range
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, widgetKey, branchId])
  @@index([pharmacyId, branchId])
}

model DashboardAlertAcknowledgement {
  id             String   @id @default(uuid())
  pharmacyId     String
  branchId       String
  alertType      String // "LOW_STOCK" | "EXPIRY" | "OUT_OF_STOCK"
  referenceId    String // medicineId or batchId
  acknowledgedBy String // userId
  acknowledgedAt DateTime @default(now())
  note           String?

  @@index([pharmacyId, branchId, alertType])
  @@index([referenceId])
}

model DashboardSnapshotCache {
  id           String   @id @default(uuid())
  pharmacyId   String
  branchId     String
  widgetKey    String
  dateRangeKey String // e.g. "2026-06-01_2026-07-02"
  payload      Json
  generatedAt  DateTime @default(now())
  expiresAt    DateTime

  @@unique([pharmacyId, branchId, widgetKey, dateRangeKey])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Minimal cross-module stub references (read-only for this module)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Module 4: Sales / POS Billing — AUTHORITATIVE (supersedes the Module 1 stub).
// Authoritative source of sales/profit data for Dashboard, Reports, Returns.
// ---------------------------------------------------------------------------

enum SaleStatus {
  COMPLETED
  VOIDED
  PARTIALLY_RETURNED // set by Module 10
  FULLY_RETURNED // set by Module 10
}

enum SessionStatus {
  OPEN
  CLOSED
}

model Sale {
  id               String                 @id @default(uuid())
  pharmacyId       String
  branchId         String
  saleNumber       String // SL-YYYY-NNNNNN
  cashierSessionId String
  cashierId        String
  customerId       String? // nullable = walk-in
  saleDate         DateTime               @default(now())
  status           SaleStatus             @default(COMPLETED)
  subTotal         Decimal                @db.Decimal(14, 2)
  discountTotal    Decimal                @default(0) @db.Decimal(14, 2)
  taxTotal         Decimal                @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal                @db.Decimal(14, 2)
  totalCost        Decimal                @db.Decimal(14, 2) // profit basis snapshot
  discountApprovedBy String?
  voidedBy         String?
  voidedAt         DateTime?
  voidReason       String?
  notes            String?
  idempotencyKey   String?
  createdAt        DateTime               @default(now())
  cashierSession   CashierSession         @relation(fields: [cashierSessionId], references: [id])
  items            SaleItem[]
  payments         SalePayment[]
  complianceRecords SaleComplianceRecord[]

  @@unique([pharmacyId, saleNumber])
  @@unique([pharmacyId, idempotencyKey])
  @@index([pharmacyId, branchId, saleDate])
  @@index([cashierSessionId])
  @@index([customerId])
}

model SaleItem {
  id                     String  @id @default(uuid())
  saleId                 String
  medicineId             String
  batchId                String? // which batch consumed (FEFO)
  quantity               Int
  unitPrice              Decimal @db.Decimal(12, 2) // snapshot at sale time
  unitCost               Decimal @db.Decimal(12, 2) // snapshot at sale time
  discountAmount         Decimal @default(0) @db.Decimal(12, 2)
  taxRatePercent         Decimal @default(0) @db.Decimal(5, 2)
  lineTotal              Decimal @db.Decimal(14, 2)
  prescriptionVerifiedBy String?
  prescriptionReference  String?
  sale                   Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([medicineId])
  @@index([batchId])
}

model SalePayment {
  id              String   @id @default(uuid())
  saleId          String
  method          String // CASH | CARD | MOBILE | WALLET | INSURANCE
  amount          Decimal  @db.Decimal(14, 2)
  referenceNumber String?
  tenderedAmount  Decimal? @db.Decimal(14, 2)
  changeDue       Decimal? @db.Decimal(14, 2)
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model SaleComplianceRecord {
  id                String   @id @default(uuid())
  saleId            String
  saleItemId        String
  type              String // PRESCRIPTION | CONTROLLED_SUBSTANCE
  prescribingDoctor String?
  patientName       String?
  patientIdNumber   String?
  quantityDispensed Int
  verifiedBy        String
  isVoided          Boolean  @default(false)
  verifiedAt        DateTime @default(now())
  sale              Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model CashierSession {
  id           String        @id @default(uuid())
  pharmacyId   String
  branchId     String
  cashierId    String
  openingFloat Decimal       @db.Decimal(14, 2)
  expectedCash Decimal?      @db.Decimal(14, 2)
  actualCash   Decimal?      @db.Decimal(14, 2)
  variance     Decimal?      @db.Decimal(14, 2)
  status       SessionStatus @default(OPEN)
  openedAt     DateTime      @default(now())
  closedAt     DateTime?
  sales        Sale[]

  @@index([pharmacyId, branchId, cashierId, status])
}

model ParkedSale {
  id           String   @id @default(uuid())
  pharmacyId   String
  branchId     String
  cashierId    String
  label        String?
  cartSnapshot Json
  createdAt    DateTime @default(now())

  @@index([pharmacyId, branchId, cashierId])
}

// ---------------------------------------------------------------------------
// Module 8 (Customers/Patients) — STUB. Minimal shape so POS can associate a
// sale with a customer today; the authoritative profile (address, loyalty,
// prescription records) is finalized in Module 8. `Sale.customerId` is a loose
// reference (no enforced relation until Module 8 lands).
// ---------------------------------------------------------------------------
model Customer {
  id         String   @id @default(uuid())
  pharmacyId String
  name       String
  phone      String?
  email      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([pharmacyId, name])
  @@index([pharmacyId, phone])
}

// ---------------------------------------------------------------------------
// Module 5: Inventory / Stock Management — AUTHORITATIVE owner of stock.
// `Inventory.currentStock` is a materialized aggregate per (medicine, branch)
// kept in lock-step with an append-only `StockLedgerEntry` ledger by
// InventoryService — the ONLY code permitted to mutate stock. It also mirrors
// the value into the transitional `Medicine.currentStock` so existing reads
// (Dashboard/Medicines/POS) keep working. `batchId` on the ledger is for
// traceability; batch quantities themselves live in MedicineBatch (Module 6).
// ---------------------------------------------------------------------------

enum StockDirection {
  IN
  OUT
}

enum StockReasonCode {
  PURCHASE_RECEIPT
  SALE
  SALES_RETURN
  PURCHASE_RETURN
  POSITIVE_ADJUSTMENT
  NEGATIVE_ADJUSTMENT
  EXPIRY_WRITE_OFF
  DAMAGE_WRITE_OFF
  TRANSFER_IN
  TRANSFER_OUT
  OPENING_STOCK
}

model Inventory {
  id             String    @id @default(uuid())
  pharmacyId     String
  branchId       String
  medicineId     String
  batchId        String? // null = the per-(medicine,branch) aggregate row
  currentStock   Int       @default(0)
  reservedStock  Int       @default(0)
  lastMovementAt DateTime?
  updatedAt      DateTime  @updatedAt

  @@unique([pharmacyId, branchId, medicineId, batchId])
  @@index([pharmacyId, branchId, medicineId])
  @@index([pharmacyId, branchId, currentStock])
}

model StockLedgerEntry {
  id              String          @id @default(uuid())
  pharmacyId      String
  branchId        String
  medicineId      String
  batchId         String?
  direction       StockDirection
  quantity        Int // always positive; direction carries the sign
  reasonCode      StockReasonCode
  referenceModule String // PURCHASE | SALE | SALES_RETURN | PURCHASE_RETURN | ADJUSTMENT | TRANSFER
  referenceId     String
  unitCostAtTime  Decimal?        @db.Decimal(12, 2)
  balanceAfter    Int // aggregate (medicine,branch) balance snapshot after this entry
  performedBy     String
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([pharmacyId, branchId, medicineId, createdAt])
  @@index([referenceModule, referenceId])
  @@index([batchId])
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model StockTransfer {
  id             String              @id @default(uuid())
  pharmacyId     String
  transferNumber String // TRF-YYYY-NNNNNN
  sourceBranchId String
  destBranchId   String
  status         TransferStatus      @default(PENDING)
  initiatedBy    String
  approvedBy     String?
  receivedBy     String?
  notes          String?
  createdAt      DateTime            @default(now())
  completedAt    DateTime?
  items          StockTransferItem[]

  @@unique([pharmacyId, transferNumber])
  @@index([pharmacyId, sourceBranchId, status])
  @@index([pharmacyId, destBranchId, status])
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  medicineId String
  batchId    String?
  quantity   Int
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

model StockReconciliation {
  id                     String   @id @default(uuid())
  pharmacyId             String
  branchId               String
  medicineId             String
  batchId                String?
  expectedQuantity       Int
  countedQuantity        Int
  variance               Int
  countedBy              String
  countedAt              DateTime @default(now())
  resolvedByAdjustmentId String? // links to Module 11's StockAdjustment once actioned
  notes                  String?

  @@index([pharmacyId, branchId, medicineId])
}

// ---------------------------------------------------------------------------
// Module 2: Medicines / Products — AUTHORITATIVE (supersedes the Module 1 stub).
// Master catalog referenced by Purchases, Sales/POS, Inventory, Batch & Expiry,
// Barcode and Reports via `medicineId`.
// ---------------------------------------------------------------------------

enum MedicineStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Medicine {
  id                     String  @id @default(uuid())
  pharmacyId             String
  branchId               String? // nullable when isGlobalAcrossBranches
  isGlobalAcrossBranches Boolean @default(false)

  // Identification
  sku            String
  genericName    String
  brandName      String?
  manufacturerId String
  categoryId     String
  subCategoryId  String?

  // Clinical / Regulatory
  dosageFormId                String
  strength                    String?
  routeOfAdministration       String?
  prescriptionRequired        Boolean @default(false)
  controlledSubstanceSchedule String? // null = not controlled
  storageCondition            String? // ROOM_TEMP | REFRIGERATED | FROZEN | CONTROLLED_ROOM_TEMP
  therapeuticClass            String?

  // Packaging / Units
  baseUnitId      String
  purchaseUnitId  String
  saleUnitId      String
  unitConversions MedicineUnitConversion[]

  // Pricing
  costPrice        Decimal @default(0) @db.Decimal(12, 2)
  mrp              Decimal @default(0) @db.Decimal(12, 2)
  sellingPrice     Decimal @default(0) @db.Decimal(12, 2)
  taxRatePercent   Decimal @default(0) @db.Decimal(5, 2)
  taxInclusive     Boolean @default(true)
  discountEligible Boolean @default(true)

  // Stock thresholds (Medicines owns thresholds; Inventory — Module 5 — will own
  // live quantity). `currentStock` is TRANSITIONAL: kept here until Module 5
  // introduces the stock ledger, so the Dashboard keeps working today.
  reorderLevel    Int  @default(10)
  reorderQuantity Int  @default(50)
  maxStockLevel   Int?
  currentStock    Int  @default(0) // TRANSITIONAL — ownership moves to Inventory (Module 5)

  // Media
  imageUrl    String?
  documentUrl String? // SDS / package insert

  // Status
  status    MedicineStatus @default(ACTIVE)
  isActive  Boolean        @default(true)
  createdBy String
  updatedBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  manufacturer Manufacturer      @relation(fields: [manufacturerId], references: [id])
  category     Category          @relation(fields: [categoryId], references: [id])
  dosageForm   DosageForm        @relation(fields: [dosageFormId], references: [id])
  baseUnit     Unit              @relation("baseUnit", fields: [baseUnitId], references: [id])
  purchaseUnit Unit              @relation("purchaseUnit", fields: [purchaseUnitId], references: [id])
  saleUnit     Unit              @relation("saleUnit", fields: [saleUnitId], references: [id])
  barcodes     MedicineBarcode[]
  priceHistory PriceHistory[]

  @@unique([pharmacyId, sku])
  @@index([pharmacyId, branchId, isActive])
  @@index([pharmacyId, categoryId])
  @@index([pharmacyId, manufacturerId])
  @@index([pharmacyId, currentStock])
}

model MedicineBarcode {
  id         String   @id @default(uuid())
  medicineId String
  pharmacyId String
  barcode    String
  isPrimary  Boolean  @default(true)
  createdAt  DateTime @default(now())
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, barcode])
  @@index([medicineId])
}

model MedicineUnitConversion {
  id               String   @id @default(uuid())
  medicineId       String
  fromUnitId       String
  toUnitId         String
  conversionFactor Int // e.g. 1 Box = 10 Strips -> factor 10
  medicine         Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([medicineId])
}

model Unit {
  id          String     @id @default(uuid())
  pharmacyId  String
  name        String // "Box", "Strip", "Tablet", "Bottle", "ml"
  symbol      String?
  baseFor     Medicine[] @relation("baseUnit")
  purchaseFor Medicine[] @relation("purchaseUnit")
  saleFor     Medicine[] @relation("saleUnit")

  @@unique([pharmacyId, name])
}

model Category {
  id         String     @id @default(uuid())
  pharmacyId String
  name       String
  parentId   String?
  isActive   Boolean    @default(true)
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  medicines  Medicine[]

  @@unique([pharmacyId, name, parentId])
}

model Manufacturer {
  id          String     @id @default(uuid())
  pharmacyId  String
  name        String
  country     String?
  contactInfo Json?
  isActive    Boolean    @default(true)
  medicines   Medicine[]

  @@unique([pharmacyId, name])
}

model DosageForm {
  id         String     @id @default(uuid())
  pharmacyId String
  name       String // Tablet, Capsule, Syrup, Injection...
  medicines  Medicine[]

  @@unique([pharmacyId, name])
}

model PriceHistory {
  id          String   @id @default(uuid())
  medicineId  String
  pharmacyId  String
  priceType   String // COST | MRP | SELLING
  oldValue    Decimal  @db.Decimal(12, 2)
  newValue    Decimal  @db.Decimal(12, 2)
  changedBy   String
  effectiveAt DateTime @default(now())
  reason      String?
  medicine    Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([medicineId, effectiveAt])
}

// ---------------------------------------------------------------------------
// Module 6: Batch & Expiry Management — AUTHORITATIVE (supersedes Module 1 stub).
// Owns batch identity + expiry logic + FEFO. `currentQuantity` is a synchronized
// read-model of Module 5's ledger for this batch (kept consistent in the same
// transaction as every InventoryService call this module initiates).
// ---------------------------------------------------------------------------
enum BatchStatus {
  FRESH
  EXPIRING_SOON
  EXPIRED
  DEPLETED
  RECALLED
}

enum RecallResolutionStatus {
  QUARANTINED
  RETURNED_TO_SUPPLIER
  DESTROYED
  RESOLVED_OTHER
}

model MedicineBatch {
  id                   String      @id @default(uuid())
  pharmacyId           String
  branchId             String
  medicineId           String
  batchNumber          String
  manufactureDate      DateTime?
  expiryDate           DateTime
  receivedQuantity     Int // original quantity received, immutable historical record
  currentQuantity      Int // live sellable quantity, synced with Module 5's ledger
  unitCostAtReceipt    Decimal     @db.Decimal(12, 2)
  status               BatchStatus @default(FRESH)
  isRecalled           Boolean     @default(false)
  expiryOverridden     Boolean     @default(false)
  expiryOverrideReason String?
  sourceGrnId          String? // loose ref to Module 3's GoodsReceipt
  sourceGrnItemId      String?
  createdAt            DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  writeOffs     BatchWriteOff[]
  recallRecords BatchRecall[]

  @@unique([pharmacyId, branchId, medicineId, batchNumber])
  @@index([pharmacyId, branchId, medicineId, expiryDate])
  @@index([pharmacyId, branchId, status])
  @@index([expiryDate])
}

model BatchWriteOff {
  id                 String   @id @default(uuid())
  pharmacyId         String
  branchId           String
  batchId            String
  quantityWrittenOff Int
  disposalMethod     String // RETURNED_TO_SUPPLIER | DESTROYED_ONSITE | THIRD_PARTY_DISPOSAL | OTHER
  disposalReference  String?
  writtenOffBy       String
  writtenOffAt       DateTime @default(now())
  notes              String?

  batch MedicineBatch @relation(fields: [batchId], references: [id])

  @@index([pharmacyId, branchId])
  @@index([batchId])
}

model BatchRecall {
  id               String                 @id @default(uuid())
  pharmacyId       String
  batchId          String
  reason           String
  sourceReference  String?
  flaggedBy        String
  flaggedAt        DateTime               @default(now())
  resolutionStatus RecallResolutionStatus @default(QUARANTINED)
  resolvedAt       DateTime?
  resolvedBy       String?
  notes            String?

  batch MedicineBatch @relation(fields: [batchId], references: [id])

  @@index([pharmacyId])
  @@index([batchId])
}

// ---------------------------------------------------------------------------
// Module 7: Suppliers Management — AUTHORITATIVE (supersedes the Module 3 stub).
// Suppliers are pharmacy-wide (not branch-scoped). PurchaseOrder/Template keep
// their real FK relation; performance/payables are read-only aggregations over
// Module 3's tables (no duplicated storage).
// ---------------------------------------------------------------------------
enum SupplierType {
  MANUFACTURER
  DISTRIBUTOR
  WHOLESALER
  LOCAL_VENDOR
}

model Supplier {
  id                    String       @id @default(uuid())
  pharmacyId            String
  companyName           String
  tradingName           String?
  supplierType          SupplierType
  taxRegistrationNumber String?
  drugLicenseNumber     String?
  drugLicenseExpiry     DateTime?
  paymentTermsCode      String       @default("NET_30") // NET_15 | NET_30 | NET_45 | NET_60 | COD | ADVANCE
  currency              String       @default("PKR")
  bankAccountDetails    Json? // reference only — sensitive, redacted for non-admin/accountant
  notes                 String?
  isActive              Boolean      @default(true)
  createdBy             String
  updatedBy             String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  contacts       SupplierContact[]
  addresses      SupplierAddress[]
  documents      SupplierDocument[]
  medicinePrices SupplierMedicinePrice[]
  purchaseOrders PurchaseOrder[]
  templates      PurchaseOrderTemplate[]

  @@unique([pharmacyId, companyName])
  @@index([pharmacyId, isActive])
  @@index([pharmacyId, supplierType])
}

model SupplierContact {
  id          String   @id @default(uuid())
  supplierId  String
  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean  @default(false)
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierAddress {
  id           String   @id @default(uuid())
  supplierId   String
  type         String // BILLING | WAREHOUSE | OTHER
  addressLine1 String
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierDocument {
  id           String    @id @default(uuid())
  supplierId   String
  documentType String // DRUG_LICENSE | TAX_CERTIFICATE | BUSINESS_REGISTRATION | CONTRACT | OTHER
  fileUrl      String
  expiryDate   DateTime?
  uploadedBy   String
  uploadedAt   DateTime  @default(now())
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([expiryDate])
}

model SupplierMedicinePrice {
  id             String    @id @default(uuid())
  supplierId     String
  medicineId     String // loose ref to Module 2
  negotiatedCost Decimal   @db.Decimal(12, 2)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  supplier       Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, medicineId, effectiveFrom])
  @@index([supplierId, medicineId])
}

model MedicinePreferredSupplier {
  id         String @id @default(uuid())
  pharmacyId String
  medicineId String // loose ref to Module 2
  supplierId String
  priority   Int    @default(1)

  @@unique([pharmacyId, medicineId, supplierId])
  @@index([medicineId])
}

// ---------------------------------------------------------------------------
// Module 3: Purchase Management — AUTHORITATIVE (supersedes the Module 1 stub).
// ---------------------------------------------------------------------------
enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model PurchaseOrder {
  id                   String               @id @default(uuid())
  pharmacyId           String
  branchId             String
  poNumber             String // PO-YYYY-NNNNNN
  supplierId           String
  status               PurchaseOrderStatus  @default(DRAFT)
  paymentStatus        PaymentStatus        @default(UNPAID)
  orderDate            DateTime             @default(now())
  expectedDeliveryDate DateTime?
  dueDate              DateTime? // payable due date (orderDate + supplier terms) on receipt
  notes                String?
  subTotal             Decimal              @default(0) @db.Decimal(14, 2)
  taxTotal             Decimal              @default(0) @db.Decimal(14, 2)
  grandTotal           Decimal              @default(0) @db.Decimal(14, 2)
  amountPaid           Decimal              @default(0) @db.Decimal(14, 2)
  isDirectGrn          Boolean              @default(false)
  createdBy            String
  approvedBy           String?
  approvedAt           DateTime?
  rejectedReason       String?
  cancelledReason      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  supplier             Supplier             @relation(fields: [supplierId], references: [id])
  items                PurchaseOrderItem[]
  goodsReceipts        GoodsReceipt[]
  payments             PurchasePayment[]
  attachments          PurchaseAttachment[]

  @@unique([pharmacyId, poNumber])
  @@index([pharmacyId, branchId, status])
  @@index([pharmacyId, supplierId])
  @@index([pharmacyId, paymentStatus])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  medicineId       String
  orderedQuantity  Int
  receivedQuantity Int           @default(0)
  expectedUnitCost Decimal       @db.Decimal(12, 2)
  taxRatePercent   Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal        Decimal       @db.Decimal(14, 2)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([medicineId])
}

model GoodsReceipt {
  id                     String               @id @default(uuid())
  pharmacyId             String
  branchId               String
  grnNumber              String // GRN-YYYY-NNNNNN
  purchaseOrderId        String
  receivedDate           DateTime             @default(now())
  receivedBy             String
  notes                  String?
  hasVariance            Boolean              @default(false)
  varianceAcknowledgedBy String?
  varianceNote           String?
  createdAt              DateTime             @default(now())
  purchaseOrder          PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items                  GoodsReceiptItem[]
  attachments            PurchaseAttachment[]

  @@unique([pharmacyId, grnNumber])
  @@index([pharmacyId, branchId, receivedDate])
  @@index([purchaseOrderId])
}

model GoodsReceiptItem {
  id                   String       @id @default(uuid())
  goodsReceiptId       String
  purchaseOrderItemId  String
  medicineId           String
  receivedQuantity     Int
  freeQuantity         Int          @default(0)
  batchNumber          String
  expiryDate           DateTime
  actualUnitCost       Decimal      @db.Decimal(12, 2)
  expiryOverridden     Boolean      @default(false)
  expiryOverrideReason String?
  goodsReceipt         GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
  @@index([medicineId, batchNumber])
}

model PurchasePayment {
  id              String        @id @default(uuid())
  pharmacyId      String
  purchaseOrderId String
  amount          Decimal       @db.Decimal(14, 2)
  paymentDate     DateTime      @default(now())
  method          String // CASH | BANK_TRANSFER | CHEQUE | CARD | OTHER
  referenceNumber String?
  recordedBy      String
  notes           String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseAttachment {
  id              String        @id @default(uuid())
  purchaseOrderId String?
  goodsReceiptId  String?
  fileUrl         String
  fileType        String // QUOTATION | INVOICE | OTHER
  uploadedBy      String
  uploadedAt      DateTime      @default(now())
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  goodsReceipt    GoodsReceipt?  @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
}

model PurchaseOrderTemplate {
  id         String   @id @default(uuid())
  pharmacyId String
  name       String
  supplierId String
  items      Json // [{ medicineId, quantity, expectedUnitCost }]
  createdBy  String
  createdAt  DateTime @default(now())
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([pharmacyId, name])
}

/// STUB — see Module 13 (Expenses)
model Expense {
  id          String   @id @default(uuid())
  pharmacyId  String
  branchId    String
  amount      Decimal  @db.Decimal(12, 2)
  expenseDate DateTime @default(now())
  category    String

  @@index([pharmacyId, branchId, expenseDate])
}

/// STUB — see Module 15 (Audit Logs)
model AuditLog {
  id         String   @id @default(uuid())
  pharmacyId String
  branchId   String
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([pharmacyId, branchId, createdAt])
}

/// STUB — see Module 18 (Settings). Dashboard reads expiry threshold,
/// currency and timezone from here (never hardcoded), with sane fallbacks
/// when a pharmacy hasn't configured settings yet.
model PharmacySettings {
  id                  String   @id @default(uuid())
  pharmacyId          String   @unique
  branchId            String?
  currency            String   @default("USD")
  timezone            String   @default("UTC")
  expiryThresholdDays Int      @default(90)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
