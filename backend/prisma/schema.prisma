// Module 1: Dashboard — Prisma schema
// Dashboard-owned models are authoritative here.
// Cross-module models are STUBS: minimal shape needed for Dashboard queries to
// compile and run. They will be superseded by the authoritative schema when
// each module is built — reconcile via `prisma migrate` at that time.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "linux-musl", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Dashboard-owned tables
// ---------------------------------------------------------------------------

model DashboardWidgetPreference {
  id         String   @id @default(uuid())
  userId     String
  pharmacyId String
  branchId   String?
  widgetKey  String // e.g. "kpi_cards", "sales_trend"
  isVisible  Boolean  @default(true)
  position   Int      @default(0)
  config     Json? // widget-specific settings e.g. default date range
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, widgetKey, branchId])
  @@index([pharmacyId, branchId])
}

model DashboardAlertAcknowledgement {
  id             String   @id @default(uuid())
  pharmacyId     String
  branchId       String
  alertType      String // "LOW_STOCK" | "EXPIRY" | "OUT_OF_STOCK"
  referenceId    String // medicineId or batchId
  acknowledgedBy String // userId
  acknowledgedAt DateTime @default(now())
  note           String?

  @@index([pharmacyId, branchId, alertType])
  @@index([referenceId])
}

model DashboardSnapshotCache {
  id           String   @id @default(uuid())
  pharmacyId   String
  branchId     String
  widgetKey    String
  dateRangeKey String // e.g. "2026-06-01_2026-07-02"
  payload      Json
  generatedAt  DateTime @default(now())
  expiresAt    DateTime

  @@unique([pharmacyId, branchId, widgetKey, dateRangeKey])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Minimal cross-module stub references (read-only for this module)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Module 4: Sales / POS Billing — AUTHORITATIVE (supersedes the Module 1 stub).
// Authoritative source of sales/profit data for Dashboard, Reports, Returns.
// ---------------------------------------------------------------------------

enum SaleStatus {
  COMPLETED
  VOIDED
  PARTIALLY_RETURNED // set by Module 10
  FULLY_RETURNED // set by Module 10
}

enum SessionStatus {
  OPEN
  CLOSED
}

model Sale {
  id                 String                 @id @default(uuid())
  pharmacyId         String
  branchId           String
  saleNumber         String // SL-YYYY-NNNNNN
  cashierSessionId   String
  cashierId          String
  customerId         String? // nullable = walk-in
  saleDate           DateTime               @default(now())
  status             SaleStatus             @default(COMPLETED)
  subTotal           Decimal                @db.Decimal(14, 2)
  discountTotal      Decimal                @default(0) @db.Decimal(14, 2)
  taxTotal           Decimal                @default(0) @db.Decimal(14, 2)
  grandTotal         Decimal                @db.Decimal(14, 2)
  totalCost          Decimal                @db.Decimal(14, 2) // profit basis snapshot
  discountApprovedBy String?
  voidedBy           String?
  voidedAt           DateTime?
  voidReason         String?
  notes              String?
  idempotencyKey     String?
  createdAt          DateTime               @default(now())
  cashierSession     CashierSession         @relation(fields: [cashierSessionId], references: [id])
  customer           Customer?              @relation(fields: [customerId], references: [id])
  items              SaleItem[]
  payments           SalePayment[]
  complianceRecords  SaleComplianceRecord[]

  @@unique([pharmacyId, saleNumber])
  @@unique([pharmacyId, idempotencyKey])
  @@index([pharmacyId, branchId, saleDate])
  @@index([cashierSessionId])
  @@index([customerId])
}

model SaleItem {
  id                     String  @id @default(uuid())
  saleId                 String
  medicineId             String
  batchId                String? // which batch consumed (FEFO)
  quantity               Int
  unitPrice              Decimal @db.Decimal(12, 2) // snapshot at sale time
  unitCost               Decimal @db.Decimal(12, 2) // snapshot at sale time
  discountAmount         Decimal @default(0) @db.Decimal(12, 2)
  taxRatePercent         Decimal @default(0) @db.Decimal(5, 2)
  lineTotal              Decimal @db.Decimal(14, 2)
  prescriptionVerifiedBy String?
  prescriptionReference  String?
  sale                   Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([medicineId])
  @@index([batchId])
}

model SalePayment {
  id              String   @id @default(uuid())
  saleId          String
  method          String // CASH | CARD | MOBILE | WALLET | INSURANCE
  amount          Decimal  @db.Decimal(14, 2)
  referenceNumber String?
  tenderedAmount  Decimal? @db.Decimal(14, 2)
  changeDue       Decimal? @db.Decimal(14, 2)
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model SaleComplianceRecord {
  id                String   @id @default(uuid())
  saleId            String
  saleItemId        String
  type              String // PRESCRIPTION | CONTROLLED_SUBSTANCE
  prescribingDoctor String?
  patientName       String?
  patientIdNumber   String?
  quantityDispensed Int
  verifiedBy        String
  isVoided          Boolean  @default(false)
  verifiedAt        DateTime @default(now())
  sale              Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model CashierSession {
  id           String        @id @default(uuid())
  pharmacyId   String
  branchId     String
  cashierId    String
  openingFloat Decimal       @db.Decimal(14, 2)
  expectedCash Decimal?      @db.Decimal(14, 2)
  actualCash   Decimal?      @db.Decimal(14, 2)
  variance     Decimal?      @db.Decimal(14, 2)
  status       SessionStatus @default(OPEN)
  openedAt     DateTime      @default(now())
  closedAt     DateTime?
  sales        Sale[]

  @@index([pharmacyId, branchId, cashierId, status])
}

model ParkedSale {
  id           String   @id @default(uuid())
  pharmacyId   String
  branchId     String
  cashierId    String
  label        String?
  cartSnapshot Json
  createdAt    DateTime @default(now())

  @@index([pharmacyId, branchId, cashierId])
}

// ---------------------------------------------------------------------------
// Module 8: Customers / Patients — AUTHORITATIVE (supersedes the Module 4 stub).
// Handles personal + health-adjacent data → elevated privacy posture. Health
// data lives in a separate table (CustomerHealthProfile) so access can be gated
// architecturally, not by field redaction. `Sale.customerId` is now a real FK.
// ---------------------------------------------------------------------------
model Customer {
  id                       String    @id @default(uuid())
  pharmacyId               String
  name                     String
  phone                    String
  email                    String?
  dateOfBirth              DateTime?
  gender                   String?
  nationalIdOrPatientId    String?
  addressLine1             String?
  addressLine2             String?
  city                     String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  isActive                 Boolean   @default(true)
  isMergedInto             String? // if set, merged away → points to surviving Customer.id
  consentHealthDataStorage Boolean   @default(false)
  consentMarketingContact  Boolean   @default(false)
  createdBy                String
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  healthProfile CustomerHealthProfile?
  prescriptions PrescriptionRecord[]
  tags          CustomerTagAssignment[]
  notes         CustomerNote[]
  sales         Sale[]

  @@unique([pharmacyId, phone])
  @@index([pharmacyId, isActive])
  @@index([pharmacyId, name])
}

model CustomerHealthProfile {
  id                        String   @id @default(uuid())
  customerId                String   @unique
  allergiesFreeText         String?
  allergyTags               String[]
  chronicConditionsFreeText String?
  chronicConditionTags      String[]
  updatedBy                 String
  updatedAt                 DateTime @updatedAt
  customer                  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model PrescriptionRecord {
  id                String    @id @default(uuid())
  pharmacyId        String
  customerId        String
  fileUrl           String?
  referenceNumber   String?
  prescribingDoctor String?
  issuedDate        DateTime?
  linkedSaleIds     String[]
  uploadedBy        String
  uploadedAt        DateTime  @default(now())
  notes             String?
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([pharmacyId, customerId])
}

model CustomerTag {
  id         String  @id @default(uuid())
  pharmacyId String
  name       String
  color      String?

  @@unique([pharmacyId, name])
}

model CustomerTagAssignment {
  id         String   @id @default(uuid())
  customerId String
  tagId      String
  assignedBy String
  assignedAt DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@index([tagId])
}

model CustomerNote {
  id         String   @id @default(uuid())
  customerId String
  note       String
  createdBy  String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Module 5: Inventory / Stock Management — AUTHORITATIVE owner of stock.
// `Inventory.currentStock` is a materialized aggregate per (medicine, branch)
// kept in lock-step with an append-only `StockLedgerEntry` ledger by
// InventoryService — the ONLY code permitted to mutate stock. It also mirrors
// the value into the transitional `Medicine.currentStock` so existing reads
// (Dashboard/Medicines/POS) keep working. `batchId` on the ledger is for
// traceability; batch quantities themselves live in MedicineBatch (Module 6).
// ---------------------------------------------------------------------------

enum StockDirection {
  IN
  OUT
}

enum StockReasonCode {
  PURCHASE_RECEIPT
  SALE
  SALES_RETURN
  PURCHASE_RETURN
  POSITIVE_ADJUSTMENT
  NEGATIVE_ADJUSTMENT
  EXPIRY_WRITE_OFF
  DAMAGE_WRITE_OFF
  TRANSFER_IN
  TRANSFER_OUT
  OPENING_STOCK
}

model Inventory {
  id             String    @id @default(uuid())
  pharmacyId     String
  branchId       String
  medicineId     String
  batchId        String? // null = the per-(medicine,branch) aggregate row
  currentStock   Int       @default(0)
  reservedStock  Int       @default(0)
  lastMovementAt DateTime?
  updatedAt      DateTime  @updatedAt

  @@unique([pharmacyId, branchId, medicineId, batchId])
  @@index([pharmacyId, branchId, medicineId])
  @@index([pharmacyId, branchId, currentStock])
}

model StockLedgerEntry {
  id              String          @id @default(uuid())
  pharmacyId      String
  branchId        String
  medicineId      String
  batchId         String?
  direction       StockDirection
  quantity        Int // always positive; direction carries the sign
  reasonCode      StockReasonCode
  referenceModule String // PURCHASE | SALE | SALES_RETURN | PURCHASE_RETURN | ADJUSTMENT | TRANSFER
  referenceId     String
  unitCostAtTime  Decimal?        @db.Decimal(12, 2)
  balanceAfter    Int // aggregate (medicine,branch) balance snapshot after this entry
  performedBy     String
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([pharmacyId, branchId, medicineId, createdAt])
  @@index([referenceModule, referenceId])
  @@index([batchId])
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model StockTransfer {
  id             String              @id @default(uuid())
  pharmacyId     String
  transferNumber String // TRF-YYYY-NNNNNN
  sourceBranchId String
  destBranchId   String
  status         TransferStatus      @default(PENDING)
  initiatedBy    String
  approvedBy     String?
  receivedBy     String?
  notes          String?
  createdAt      DateTime            @default(now())
  completedAt    DateTime?
  items          StockTransferItem[]

  @@unique([pharmacyId, transferNumber])
  @@index([pharmacyId, sourceBranchId, status])
  @@index([pharmacyId, destBranchId, status])
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  medicineId String
  batchId    String?
  quantity   Int
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

model StockReconciliation {
  id                     String   @id @default(uuid())
  pharmacyId             String
  branchId               String
  medicineId             String
  batchId                String?
  expectedQuantity       Int
  countedQuantity        Int
  variance               Int
  countedBy              String
  countedAt              DateTime @default(now())
  resolvedByAdjustmentId String? // links to Module 11's StockAdjustment once actioned
  notes                  String?

  @@index([pharmacyId, branchId, medicineId])
}

// ---------------------------------------------------------------------------
// Module 2: Medicines / Products — AUTHORITATIVE (supersedes the Module 1 stub).
// Master catalog referenced by Purchases, Sales/POS, Inventory, Batch & Expiry,
// Barcode and Reports via `medicineId`.
// ---------------------------------------------------------------------------

enum MedicineStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Medicine {
  id                     String  @id @default(uuid())
  pharmacyId             String
  branchId               String? // nullable when isGlobalAcrossBranches
  isGlobalAcrossBranches Boolean @default(false)

  // Identification
  sku            String
  genericName    String
  brandName      String?
  manufacturerId String
  categoryId     String
  subCategoryId  String?

  // Clinical / Regulatory
  dosageFormId                String
  strength                    String?
  routeOfAdministration       String?
  prescriptionRequired        Boolean @default(false)
  controlledSubstanceSchedule String? // null = not controlled
  storageCondition            String? // ROOM_TEMP | REFRIGERATED | FROZEN | CONTROLLED_ROOM_TEMP
  therapeuticClass            String?

  // Packaging / Units
  baseUnitId      String
  purchaseUnitId  String
  saleUnitId      String
  unitConversions MedicineUnitConversion[]

  // Physical storage location (shelf/rack). Optional lookup — Module 2 extension.
  rackId String?

  // Pricing
  costPrice        Decimal @default(0) @db.Decimal(12, 2)
  mrp              Decimal @default(0) @db.Decimal(12, 2)
  sellingPrice     Decimal @default(0) @db.Decimal(12, 2)
  taxRatePercent   Decimal @default(0) @db.Decimal(5, 2)
  taxInclusive     Boolean @default(true)
  discountEligible Boolean @default(true)

  // Stock thresholds (Medicines owns thresholds; Inventory — Module 5 — will own
  // live quantity). `currentStock` is TRANSITIONAL: kept here until Module 5
  // introduces the stock ledger, so the Dashboard keeps working today.
  reorderLevel    Int  @default(10)
  reorderQuantity Int  @default(50)
  maxStockLevel   Int?
  currentStock    Int  @default(0) // TRANSITIONAL — ownership moves to Inventory (Module 5)

  // Media
  imageUrl    String?
  documentUrl String? // SDS / package insert

  // Status
  status    MedicineStatus @default(ACTIVE)
  isActive  Boolean        @default(true)
  createdBy String
  updatedBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  manufacturer Manufacturer      @relation(fields: [manufacturerId], references: [id])
  category     Category          @relation(fields: [categoryId], references: [id])
  dosageForm   DosageForm        @relation(fields: [dosageFormId], references: [id])
  baseUnit     Unit              @relation("baseUnit", fields: [baseUnitId], references: [id])
  purchaseUnit Unit              @relation("purchaseUnit", fields: [purchaseUnitId], references: [id])
  saleUnit     Unit              @relation("saleUnit", fields: [saleUnitId], references: [id])
  rack         Rack?             @relation(fields: [rackId], references: [id])
  barcodes     MedicineBarcode[]
  priceHistory PriceHistory[]

  @@unique([pharmacyId, sku])
  @@index([pharmacyId, branchId, isActive])
  @@index([pharmacyId, categoryId])
  @@index([pharmacyId, manufacturerId])
  @@index([pharmacyId, currentStock])
}

model MedicineBarcode {
  id         String   @id @default(uuid())
  medicineId String
  pharmacyId String
  barcode    String
  isPrimary  Boolean  @default(true)
  createdAt  DateTime @default(now())
  medicine   Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([pharmacyId, barcode])
  @@index([medicineId])
}

model MedicineUnitConversion {
  id               String   @id @default(uuid())
  medicineId       String
  fromUnitId       String
  toUnitId         String
  conversionFactor Int // e.g. 1 Box = 10 Strips -> factor 10
  medicine         Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([medicineId])
}

model Unit {
  id          String     @id @default(uuid())
  pharmacyId  String
  name        String // "Box", "Strip", "Tablet", "Bottle", "ml"
  symbol      String?
  baseFor     Medicine[] @relation("baseUnit")
  purchaseFor Medicine[] @relation("purchaseUnit")
  saleFor     Medicine[] @relation("saleUnit")

  @@unique([pharmacyId, name])
}

/// Physical storage location (shelf / rack / bin). A lightweight Module 2 lookup,
/// quick-addable inline from the Add Medicine and GRN screens.
model Rack {
  id          String     @id @default(uuid())
  pharmacyId  String
  branchId    String? // null = shared across branches
  name        String // "R-01", "Cold Chain A", "Front Counter"
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  medicines   Medicine[]

  @@unique([pharmacyId, name])
  @@index([pharmacyId, isActive])
}

/// How a discount / tax value is interpreted: a percentage of the base, or a flat
/// currency amount ("lumpsum"). Used at both GRN line and invoice level.
enum TaxDiscountMode {
  PERCENT
  AMOUNT
}

model Category {
  id         String     @id @default(uuid())
  pharmacyId String
  name       String
  parentId   String?
  isActive   Boolean    @default(true)
  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  medicines  Medicine[]

  @@unique([pharmacyId, name, parentId])
}

model Manufacturer {
  id          String     @id @default(uuid())
  pharmacyId  String
  name        String
  country     String?
  contactInfo Json?
  isActive    Boolean    @default(true)
  medicines   Medicine[]

  @@unique([pharmacyId, name])
}

model DosageForm {
  id         String     @id @default(uuid())
  pharmacyId String
  name       String // Tablet, Capsule, Syrup, Injection...
  medicines  Medicine[]

  @@unique([pharmacyId, name])
}

model PriceHistory {
  id          String   @id @default(uuid())
  medicineId  String
  pharmacyId  String
  priceType   String // COST | MRP | SELLING
  oldValue    Decimal  @db.Decimal(12, 2)
  newValue    Decimal  @db.Decimal(12, 2)
  changedBy   String
  effectiveAt DateTime @default(now())
  reason      String?
  medicine    Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([medicineId, effectiveAt])
}

// ---------------------------------------------------------------------------
// Module 6: Batch & Expiry Management — AUTHORITATIVE (supersedes Module 1 stub).
// Owns batch identity + expiry logic + FEFO. `currentQuantity` is a synchronized
// read-model of Module 5's ledger for this batch (kept consistent in the same
// transaction as every InventoryService call this module initiates).
// ---------------------------------------------------------------------------
enum BatchStatus {
  FRESH
  EXPIRING_SOON
  EXPIRED
  DEPLETED
  RECALLED
}

enum RecallResolutionStatus {
  QUARANTINED
  RETURNED_TO_SUPPLIER
  DESTROYED
  RESOLVED_OTHER
}

model MedicineBatch {
  id                   String      @id @default(uuid())
  pharmacyId           String
  branchId             String
  medicineId           String
  batchNumber          String
  manufactureDate      DateTime?
  expiryDate           DateTime
  receivedQuantity     Int // original quantity received, immutable historical record
  currentQuantity      Int // live sellable quantity, synced with Module 5's ledger
  unitCostAtReceipt    Decimal     @db.Decimal(12, 2)
  status               BatchStatus @default(FRESH)
  isRecalled           Boolean     @default(false)
  expiryOverridden     Boolean     @default(false)
  expiryOverrideReason String?
  sourceGrnId          String? // loose ref to Module 3's GoodsReceipt
  sourceGrnItemId      String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  writeOffs     BatchWriteOff[]
  recallRecords BatchRecall[]

  @@unique([pharmacyId, branchId, medicineId, batchNumber])
  @@index([pharmacyId, branchId, medicineId, expiryDate])
  @@index([pharmacyId, branchId, status])
  @@index([expiryDate])
}

model BatchWriteOff {
  id                 String   @id @default(uuid())
  pharmacyId         String
  branchId           String
  batchId            String
  quantityWrittenOff Int
  disposalMethod     String // RETURNED_TO_SUPPLIER | DESTROYED_ONSITE | THIRD_PARTY_DISPOSAL | OTHER
  disposalReference  String?
  writtenOffBy       String
  writtenOffAt       DateTime @default(now())
  notes              String?

  batch MedicineBatch @relation(fields: [batchId], references: [id])

  @@index([pharmacyId, branchId])
  @@index([batchId])
}

model BatchRecall {
  id               String                 @id @default(uuid())
  pharmacyId       String
  batchId          String
  reason           String
  sourceReference  String?
  flaggedBy        String
  flaggedAt        DateTime               @default(now())
  resolutionStatus RecallResolutionStatus @default(QUARANTINED)
  resolvedAt       DateTime?
  resolvedBy       String?
  notes            String?

  batch MedicineBatch @relation(fields: [batchId], references: [id])

  @@index([pharmacyId])
  @@index([batchId])
}

// ---------------------------------------------------------------------------
// Module 7: Suppliers Management — AUTHORITATIVE (supersedes the Module 3 stub).
// Suppliers are pharmacy-wide (not branch-scoped). PurchaseOrder/Template keep
// their real FK relation; performance/payables are read-only aggregations over
// Module 3's tables (no duplicated storage).
// ---------------------------------------------------------------------------
enum SupplierType {
  MANUFACTURER
  DISTRIBUTOR
  WHOLESALER
  LOCAL_VENDOR
}

model Supplier {
  id                    String       @id @default(uuid())
  pharmacyId            String
  companyName           String
  tradingName           String?
  supplierType          SupplierType
  taxRegistrationNumber String?
  drugLicenseNumber     String?
  drugLicenseExpiry     DateTime?
  paymentTermsCode      String       @default("NET_30") // NET_15 | NET_30 | NET_45 | NET_60 | COD | ADVANCE
  currency              String       @default("PKR")
  bankAccountDetails    Json? // reference only — sensitive, redacted for non-admin/accountant
  notes                 String?
  isActive              Boolean      @default(true)
  createdBy             String
  updatedBy             String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  contacts       SupplierContact[]
  addresses      SupplierAddress[]
  documents      SupplierDocument[]
  medicinePrices SupplierMedicinePrice[]
  purchaseOrders PurchaseOrder[]
  templates      PurchaseOrderTemplate[]

  @@unique([pharmacyId, companyName])
  @@index([pharmacyId, isActive])
  @@index([pharmacyId, supplierType])
}

model SupplierContact {
  id          String   @id @default(uuid())
  supplierId  String
  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean  @default(false)
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierAddress {
  id           String   @id @default(uuid())
  supplierId   String
  type         String // BILLING | WAREHOUSE | OTHER
  addressLine1 String
  addressLine2 String?
  city         String?
  state        String?
  country      String?
  postalCode   String?
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model SupplierDocument {
  id           String    @id @default(uuid())
  supplierId   String
  documentType String // DRUG_LICENSE | TAX_CERTIFICATE | BUSINESS_REGISTRATION | CONTRACT | OTHER
  fileUrl      String
  expiryDate   DateTime?
  uploadedBy   String
  uploadedAt   DateTime  @default(now())
  supplier     Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([expiryDate])
}

model SupplierMedicinePrice {
  id             String    @id @default(uuid())
  supplierId     String
  medicineId     String // loose ref to Module 2
  negotiatedCost Decimal   @db.Decimal(12, 2)
  effectiveFrom  DateTime  @default(now())
  effectiveTo    DateTime?
  createdBy      String
  createdAt      DateTime  @default(now())
  supplier       Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, medicineId, effectiveFrom])
  @@index([supplierId, medicineId])
}

model MedicinePreferredSupplier {
  id         String @id @default(uuid())
  pharmacyId String
  medicineId String // loose ref to Module 2
  supplierId String
  priority   Int    @default(1)

  @@unique([pharmacyId, medicineId, supplierId])
  @@index([medicineId])
}

// ---------------------------------------------------------------------------
// Module 3: Purchase Management — AUTHORITATIVE (supersedes the Module 1 stub).
// ---------------------------------------------------------------------------
enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model PurchaseOrder {
  id                   String               @id @default(uuid())
  pharmacyId           String
  branchId             String
  poNumber             String // PO-YYYY-NNNNNN
  supplierId           String
  status               PurchaseOrderStatus  @default(DRAFT)
  paymentStatus        PaymentStatus        @default(UNPAID)
  orderDate            DateTime             @default(now())
  expectedDeliveryDate DateTime?
  dueDate              DateTime? // payable due date (orderDate + supplier terms) on receipt
  notes                String?
  subTotal             Decimal              @default(0) @db.Decimal(14, 2)
  taxTotal             Decimal              @default(0) @db.Decimal(14, 2)
  grandTotal           Decimal              @default(0) @db.Decimal(14, 2)
  amountPaid           Decimal              @default(0) @db.Decimal(14, 2)
  isDirectGrn          Boolean              @default(false)
  createdBy            String
  approvedBy           String?
  approvedAt           DateTime?
  rejectedReason       String?
  cancelledReason      String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  supplier             Supplier             @relation(fields: [supplierId], references: [id])
  items                PurchaseOrderItem[]
  goodsReceipts        GoodsReceipt[]
  payments             PurchasePayment[]
  attachments          PurchaseAttachment[]

  @@unique([pharmacyId, poNumber])
  @@index([pharmacyId, branchId, status])
  @@index([pharmacyId, supplierId])
  @@index([pharmacyId, paymentStatus])
}

model PurchaseOrderItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  medicineId       String
  orderedQuantity  Int
  receivedQuantity Int           @default(0)
  expectedUnitCost Decimal       @db.Decimal(12, 2)
  taxRatePercent   Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal        Decimal       @db.Decimal(14, 2)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([medicineId])
}

model GoodsReceipt {
  id                     String               @id @default(uuid())
  pharmacyId             String
  branchId               String
  grnNumber              String // GRN-YYYY-NNNNNN
  purchaseOrderId        String
  receivedDate           DateTime             @default(now())
  receivedBy             String
  supplierInvoiceNumber  String? // supplier's own invoice/bill number
  supplierInvoiceDate    DateTime?
  notes                  String?
  hasVariance            Boolean              @default(false)
  varianceAcknowledgedBy String?
  varianceNote           String?

  // Invoice-level (bulk) adjustments applied after summing all line nets.
  invoiceDiscountMode    TaxDiscountMode @default(AMOUNT)
  invoiceDiscountValue   Decimal         @default(0) @db.Decimal(14, 2)
  invoiceSalesTaxMode    TaxDiscountMode @default(PERCENT)
  invoiceSalesTaxValue   Decimal         @default(0) @db.Decimal(14, 2)
  invoiceAdvanceTaxMode  TaxDiscountMode @default(AMOUNT)
  invoiceAdvanceTaxValue Decimal         @default(0) @db.Decimal(14, 2)
  subTotal               Decimal         @default(0) @db.Decimal(14, 2) // sum of line nets
  grandTotal             Decimal         @default(0) @db.Decimal(14, 2) // after invoice-level adjustments

  createdAt              DateTime             @default(now())
  purchaseOrder          PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items                  GoodsReceiptItem[]
  attachments            PurchaseAttachment[]

  @@unique([pharmacyId, grnNumber])
  @@index([pharmacyId, branchId, receivedDate])
  @@index([purchaseOrderId])
}

model GoodsReceiptItem {
  id                   String       @id @default(uuid())
  goodsReceiptId       String
  purchaseOrderItemId  String
  medicineId           String
  receivedQuantity     Int // full packs (purchase units) received
  looseUnitQuantity    Int          @default(0) // extra loose base-units on top of full packs
  freeQuantity         Int          @default(0) // bonus / free packs (not billed)
  batchNumber          String
  expiryDate           DateTime
  actualUnitCost       Decimal      @db.Decimal(12, 2)
  rackId               String? // where this batch is shelved (no FK — free-form placement)

  // Per-line discount / sales tax / advance tax. Each stores the raw entered
  // value plus how to read it (percent of line gross, or a flat amount).
  discountMode    TaxDiscountMode @default(AMOUNT)
  discountValue   Decimal         @default(0) @db.Decimal(12, 2)
  salesTaxMode    TaxDiscountMode @default(PERCENT)
  salesTaxValue   Decimal         @default(0) @db.Decimal(12, 2)
  advanceTaxMode  TaxDiscountMode @default(AMOUNT)
  advanceTaxValue Decimal         @default(0) @db.Decimal(12, 2)
  lineNetTotal    Decimal         @default(0) @db.Decimal(14, 2) // computed: gross - discount + salesTax + advanceTax

  expiryOverridden     Boolean      @default(false)
  expiryOverrideReason String?
  goodsReceipt         GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([goodsReceiptId])
  @@index([medicineId, batchNumber])
}

model PurchasePayment {
  id              String        @id @default(uuid())
  pharmacyId      String
  purchaseOrderId String
  amount          Decimal       @db.Decimal(14, 2)
  paymentDate     DateTime      @default(now())
  method          String // CASH | BANK_TRANSFER | CHEQUE | CARD | OTHER
  referenceNumber String?
  recordedBy      String
  notes           String?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseAttachment {
  id              String         @id @default(uuid())
  purchaseOrderId String?
  goodsReceiptId  String?
  fileUrl         String
  fileType        String // QUOTATION | INVOICE | OTHER
  uploadedBy      String
  uploadedAt      DateTime       @default(now())
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  goodsReceipt    GoodsReceipt?  @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
}

model PurchaseOrderTemplate {
  id         String   @id @default(uuid())
  pharmacyId String
  name       String
  supplierId String
  items      Json // [{ medicineId, quantity, expectedUnitCost }]
  createdBy  String
  createdAt  DateTime @default(now())
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([pharmacyId, name])
}

/// STUB — see Module 13 (Expenses)
model Expense {
  id          String   @id @default(uuid())
  pharmacyId  String
  branchId    String
  amount      Decimal  @db.Decimal(12, 2)
  expenseDate DateTime @default(now())
  category    String

  @@index([pharmacyId, branchId, expenseDate])
}

/// STUB — see Module 15 (Audit Logs)
// ---------------------------------------------------------------------------
// Module 15: Audit Logs — AUTHORITATIVE (supersedes the Module 1 stub). The
// system-wide "who did what, when" trail every module writes to via
// AuditLogService.record(). Immutable (no update/delete endpoints) + optional
// per-pharmacy hash-chain for tamper-evidence.
// ---------------------------------------------------------------------------
enum AuditSeverity {
  ROUTINE
  SENSITIVE
  CRITICAL
}

model AuditLog {
  id              String        @id @default(uuid())
  pharmacyId      String
  branchId        String?
  action          String
  entityType      String
  entityId        String?
  performedBy     String
  performedByName String?
  severity        AuditSeverity @default(ROUTINE)
  metadata        Json?
  ipAddress       String?
  userAgent       String?
  recordHash      String?
  previousHash    String?
  createdAt       DateTime      @default(now())

  @@index([pharmacyId, branchId, createdAt])
  @@index([pharmacyId, entityType, entityId])
  @@index([pharmacyId, performedBy, createdAt])
  @@index([pharmacyId, severity, createdAt])
  @@index([action])
}

model AuditRetentionPolicy {
  id                      String   @id @default(uuid())
  pharmacyId              String   @unique
  detailedRetentionMonths Int      @default(24)
  archiveAfterMonths      Int?
  updatedBy               String
  updatedAt               DateTime @updatedAt
}

model AuditIntegrityCheck {
  id               String   @id @default(uuid())
  pharmacyId       String
  checkedAt        DateTime @default(now())
  recordsChecked   Int
  chainIntact      Boolean
  brokenAtRecordId String?
  notes            String?

  @@index([pharmacyId, checkedAt])
}

/// STUB — see Module 18 (Settings). Dashboard reads expiry threshold,
/// currency and timezone from here (never hardcoded), with sane fallbacks
/// when a pharmacy hasn't configured settings yet.
model PharmacySettings {
  id                  String   @id @default(uuid())
  pharmacyId          String   @unique
  branchId            String?
  currency            String   @default("USD")
  timezone            String   @default("UTC")
  expiryThresholdDays Int      @default(90)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Module 16: Users & Roles (RBAC) — AUTHORITATIVE identity/roles/branch-access.
// Supabase Auth owns credentials; `User.authUserId` bridges to it. Every other
// module's @Roles() reads lowercase role claims from the JWT (app_metadata),
// which this module keeps in sync with `UserRoleAssignment`/`UserBranchAccess`.
// SystemRole is UPPERCASE here (DB enum); it maps to the lowercase PharmacyRole
// used in JWT claims + guards. Additions only — no existing table changed.
// ---------------------------------------------------------------------------
enum UserStatus {
  PENDING_ACTIVATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum SystemRole {
  SUPER_ADMIN
  ADMIN
  PHARMACIST
  INVENTORY_MANAGER
  CASHIER
  ACCOUNTANT
  AUDITOR
}

enum StepUpStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED
}

model User {
  id              String     @id @default(uuid())
  pharmacyId      String
  authUserId      String     @unique
  name            String
  email           String
  phone           String?
  employeeId      String?
  profilePhotoUrl String?
  status          UserStatus @default(PENDING_ACTIVATION)
  createdBy       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deactivatedAt   DateTime?
  deactivatedBy   String?

  roles               UserRoleAssignment[]
  branchAccess        UserBranchAccess[]
  permissionOverrides UserPermissionOverride[]
  loginActivity       LoginActivity[]

  @@unique([pharmacyId, email])
  @@index([pharmacyId, status])
}

model UserRoleAssignment {
  id         String     @id @default(uuid())
  userId     String
  role       SystemRole
  assignedBy String
  assignedAt DateTime   @default(now())
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model UserBranchAccess {
  id        String   @id @default(uuid())
  userId    String
  branchId  String
  isDefault Boolean  @default(false)
  grantedBy String
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

enum PermissionOverrideEffect {
  GRANT // adds a permission the user's role(s) don't include
  REVOKE // removes a permission the user's role(s) would normally include
}

model UserPermissionOverride {
  id            String                   @id @default(uuid())
  userId        String
  permissionKey String
  effect        PermissionOverrideEffect @default(GRANT)
  grantedBy     String
  grantedAt     DateTime                 @default(now())
  reason        String?
  expiresAt     DateTime?
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([userId])
}

model LoginActivity {
  id            String   @id @default(uuid())
  userId        String
  loginAt       DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  success       Boolean  @default(true)
  failureReason String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loginAt])
}

model StepUpVerification {
  id                String       @id @default(uuid())
  pharmacyId        String
  requestedByUserId String
  verifiedByUserId  String?
  actionType        String
  referenceModule   String
  referenceId       String?
  requiredRole      SystemRole
  status            StepUpStatus @default(PENDING)
  requestedAt       DateTime     @default(now())
  resolvedAt        DateTime?
  expiresAt         DateTime

  @@index([requestedByUserId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Module 18: Settings & System Configuration — the central, cached config store
// every module reads via SettingsService.get(). Flexible key/value so future
// modules add settings without a migration. Resolution: branch override →
// pharmacy-wide value → SettingDefinition.defaultValue. Key convention:
// module.category.settingName (e.g. sales.discount.autoApprovedPercent).
// ---------------------------------------------------------------------------
enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  ENUM
  JSON
}

enum SettingScope {
  PHARMACY
  BRANCH
}

model SettingDefinition {
  id             String           @id @default(uuid())
  key            String           @unique
  label          String
  description    String?
  category       String
  valueType      SettingValueType
  defaultValue   Json
  validationRule Json?
  scope          SettingScope     @default(PHARMACY)
  isSensitive    Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@index([category])
}

model SettingValue {
  id         String   @id @default(uuid())
  pharmacyId String
  branchId   String? // null = pharmacy-wide; non-null = branch override
  settingKey String
  value      Json
  updatedBy  String
  updatedAt  DateTime @updatedAt

  @@unique([pharmacyId, branchId, settingKey])
  @@index([pharmacyId, settingKey])
}

model SettingChangeHistory {
  id         String   @id @default(uuid())
  pharmacyId String
  branchId   String?
  settingKey String
  oldValue   Json?
  newValue   Json
  changedBy  String
  changedAt  DateTime @default(now())

  @@index([pharmacyId, settingKey, changedAt])
}

// ---------------------------------------------------------------------------
// MODULE 10 — Sales Returns. A return is a NEW, separate transaction that
// references the original Sale/SaleItem (Module 4) but never mutates them
// (only Sale.status transitions, via SalesService.markReturnStatus). Stock is
// restored via Module 5/6 only for RESALEABLE items. Controlled substances are
// hard-blocked from return. All cross-module refs are loose (no FK relations
// into Modules 4/8) to preserve ownership boundaries — same discipline as the
// batch↔GRN reference.
// ---------------------------------------------------------------------------

enum RefundMethod {
  CASH
  CARD
  STORE_CREDIT
  EXCHANGE
  NO_REFUND
}

enum ConditionAssessment {
  RESALEABLE
  NOT_RESALEABLE
}

enum ReturnReasonCode {
  CUSTOMER_CHANGED_MIND
  INCORRECT_ITEM_DISPENSED
  ADVERSE_REACTION
  DAMAGED_DEFECTIVE
  PRESCRIPTION_CHANGED
  OTHER
}

model SalesReturn {
  id                String            @id @default(uuid())
  pharmacyId        String
  branchId          String // the branch physically PROCESSING the return (may differ from original sale's branch — cross-branch returns allowed)
  returnNumber      String // RTN-YYYY-NNNNNN
  originalSaleId    String // loose ref to Module 4's Sale
  customerId        String? // inherited from the original sale; null for walk-ins
  processedBy       String
  approvedBy        String? // set when elevated (prescription/clinical) approval was required
  returnDate        DateTime          @default(now())
  totalRefundAmount Decimal           @db.Decimal(14, 2)
  refundMethod      RefundMethod
  refundReference   String? // card/store-credit/exchange reference
  exchangeSaleId    String? // linked replacement sale when refundMethod = EXCHANGE
  notes             String?
  items             SalesReturnItem[]
  createdAt         DateTime          @default(now())

  @@unique([pharmacyId, returnNumber])
  @@index([pharmacyId, branchId, returnDate])
  @@index([originalSaleId])
  @@index([customerId])
}

model SalesReturnItem {
  id                  String              @id @default(uuid())
  salesReturnId       String
  originalSaleItemId  String // loose ref to Module 4's SaleItem — the over-return guard key
  medicineId          String
  batchId             String? // original batch (for resaleable restoration / traceability)
  quantityReturned    Int
  unitPriceAtSale     Decimal             @db.Decimal(12, 2) // snapshot copied from the original SaleItem
  refundAmountForLine Decimal             @db.Decimal(14, 2)
  conditionAssessment ConditionAssessment
  reasonCode          ReturnReasonCode
  reasonNote          String?
  conditionPhotoUrl   String?
  restoredToStock     Boolean             @default(false) // true when RESALEABLE units rejoined sellable inventory
  flaggedForReview    Boolean             @default(false) // true when the original batch was defunct — needs inventory_manager attention
  salesReturn         SalesReturn         @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@index([salesReturnId])
  @@index([originalSaleItemId])
  @@index([medicineId])
}

model StoreCreditBalance {
  id         String   @id @default(uuid())
  pharmacyId String
  customerId String
  balance    Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt

  @@unique([pharmacyId, customerId])
}

model StoreCreditLedgerEntry {
  id              String   @id @default(uuid())
  pharmacyId      String
  customerId      String
  direction       String // CREDIT | DEBIT
  amount          Decimal  @db.Decimal(12, 2)
  balanceAfter    Decimal  @db.Decimal(12, 2)
  referenceModule String // SALES_RETURN | SALE
  referenceId     String
  performedBy     String
  createdAt       DateTime @default(now())

  @@index([pharmacyId, customerId, createdAt])
}

// ---------------------------------------------------------------------------
// MODULE 9 — Purchase Returns. Mirror of Module 10 but flowing OUT to the
// supplier, against Module 3's GoodsReceipt (never mutated). Stock leaves via
// Module 5 (recordStockOut, reason PURCHASE_RETURN); no resaleable branching —
// the goods physically leave the pharmacy. Settlement tracks the supplier
// credit note (financial reconciliation), separate from the one-time stock
// removal. All cross-module refs are loose (no FK into Modules 3/6/7).
// ---------------------------------------------------------------------------

enum PurchaseReturnSettlementStatus {
  PENDING // sent, awaiting supplier confirmation/credit
  CREDITED // supplier issued a full credit note
  PARTIALLY_CREDITED // supplier credited less than expected
  REJECTED // supplier declined the return (no stock restoration — financial outcome only)
}

enum PurchaseReturnReasonCode {
  NEAR_EXPIRY
  DAMAGED_DEFECTIVE
  WRONG_ITEM_SHIPPED
  QUALITY_RECALL
  EXCESS_STOCK
  OTHER
}

model PurchaseReturn {
  id                    String                         @id @default(uuid())
  pharmacyId            String
  branchId              String
  returnNumber          String // PRTN-YYYY-NNNNNN
  originalGrnId         String // loose ref to Module 3's GoodsReceipt
  supplierId            String // inherited from the originating PO (Module 7)
  initiatedBy           String
  returnDate            DateTime                       @default(now())
  settlementStatus      PurchaseReturnSettlementStatus @default(PENDING)
  expectedCreditAmount  Decimal                        @db.Decimal(14, 2)
  actualCreditedAmount  Decimal?                       @db.Decimal(14, 2)
  supplierCreditNoteRef String?
  settledAt             DateTime?
  settledBy             String?
  notes                 String?
  items                 PurchaseReturnItem[]
  createdAt             DateTime                       @default(now())

  @@unique([pharmacyId, returnNumber])
  @@index([pharmacyId, branchId, returnDate])
  @@index([originalGrnId])
  @@index([supplierId, settlementStatus])
}

model PurchaseReturnItem {
  id                String                   @id @default(uuid())
  purchaseReturnId  String
  originalGrnItemId String // loose ref to Module 3's GoodsReceiptItem — the over-return guard key
  medicineId        String
  batchId           String? // resolved Module 6 batch (by GRN item's batchNumber)
  quantityReturned  Int
  unitCostAtReceipt Decimal                  @db.Decimal(12, 2) // snapshot from the GRN item
  reasonCode        PurchaseReturnReasonCode
  reasonNote        String?
  relatedRecallId   String? // loose ref to Module 6's BatchRecall when reasonCode = QUALITY_RECALL
  photoUrl          String?
  purchaseReturn    PurchaseReturn           @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@index([purchaseReturnId])
  @@index([originalGrnItemId])
  @@index([medicineId])
}

// ===========================================================================
// PLATFORM / SUPER-ADMIN LAYER (multi-tenant SaaS management)
// Sits ABOVE Modules 1–18. Its users are the software vendor's own staff
// (PlatformStaffUser), never a pharmacy's employees. `Pharmacy` is the tenant
// entity that every module's `pharmacyId` column refers to.
// ===========================================================================

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  ARCHIVED
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT
  BILLING_OPS
}

/// The tenant. Every Module 1–18 row's `pharmacyId` references this id. FK
/// constraints across those modules are intentionally NOT added yet (data-
/// preserving); the relationship is enforced in application code + this layer.
model Pharmacy {
  id                 String        @id @default(uuid())
  businessName       String
  contactEmail       String
  contactPhone       String?
  status             TenantStatus  @default(TRIAL)
  subscriptionPlanId String?
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  billingStatus      BillingStatus @default(TRIAL)
  nextRenewalDate    DateTime?
  suspendedAt        DateTime?
  suspendedReason    String?
  archivedAt         DateTime?
  archivedReason     String?
  notes              String?
  createdBy          String // platform staff user id who onboarded this tenant
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])

  @@index([status])
  @@index([billingStatus])
}

model SubscriptionPlan {
  id                     String     @id @default(uuid())
  name                   String
  priceAmount            Decimal    @db.Decimal(10, 2)
  billingInterval        String // MONTHLY | ANNUAL
  maxUsers               Int?
  maxBranches            Int?
  maxMonthlyTransactions Int?
  includedFeatures       Json?
  isActive               Boolean    @default(true)
  createdAt              DateTime   @default(now())
  updatedAt             DateTime    @updatedAt
  pharmacies             Pharmacy[]

  @@unique([name])
}

/// Platform staff (vendor employees). A DELIBERATELY separate identity space
/// from Module 16's tenant-scoped `User`. `authUserId` links to Supabase Auth.
model PlatformStaffUser {
  id         String       @id @default(uuid())
  authUserId String       @unique
  name       String
  email      String       @unique
  role       PlatformRole
  status     String       @default("ACTIVE") // ACTIVE | SUSPENDED
  createdBy  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([role])
}

model ImpersonationSession {
  id                  String    @id @default(uuid())
  platformStaffUserId String
  platformStaffEmail  String
  targetPharmacyId    String
  targetUserId        String
  targetUserEmail     String?
  reason              String
  startedAt           DateTime  @default(now())
  endedAt             DateTime?
  endedReason         String? // ENDED | EXPIRED | TENANT_ARCHIVED
  expiresAt           DateTime

  @@index([platformStaffUserId])
  @@index([targetPharmacyId])
}

model PlatformAnnouncement {
  id        String    @id @default(uuid())
  title     String
  message   String
  severity  String    @default("INFO") // INFO | WARNING | CRITICAL
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  isActive  Boolean   @default(true)
  createdBy String
  createdAt DateTime  @default(now())
}

model FeatureFlag {
  id                    String   @id @default(uuid())
  key                   String   @unique
  description           String?
  isGloballyEnabled     Boolean  @default(false)
  enabledForPharmacyIds String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

/// This layer's OWN audit trail — distinct from each tenant's Module 15 log.
/// Maximally sensitive given the cross-tenant blast radius.
model PlatformAuditLog {
  id           String   @id @default(uuid())
  platformStaffUserId String
  platformStaffEmail  String
  action       String
  entityType   String
  entityId     String?
  targetPharmacyId String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([platformStaffUserId])
  @@index([action])
  @@index([targetPharmacyId])
}

// ===========================================================================
// MODULE 11: STOCK ADJUSTMENT — the ONLY sanctioned manual stock correction.
// Reason-coded, threshold-gated (auto-approve vs pending), two-person approval,
// fully audited. Executes stock exclusively via Module 5 InventoryService with
// POSITIVE_ADJUSTMENT / NEGATIVE_ADJUSTMENT reason codes.
// ===========================================================================

enum AdjustmentDirection {
  INCREASE
  DECREASE
}

enum AdjustmentReasonCode {
  PHYSICAL_COUNT_CORRECTION
  DAMAGED_BREAKAGE
  THEFT_LOSS_SUSPECTED
  DATA_ENTRY_CORRECTION
  EXPIRED_FOUND_OUTSIDE_PROCESS
  OTHER
}

enum AdjustmentStatus {
  AUTO_APPROVED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model StockAdjustment {
  id                     String               @id @default(uuid())
  pharmacyId             String
  branchId               String
  adjustmentNumber       String // ADJ-YYYY-NNNNNN
  medicineId             String
  batchId                String?
  direction              AdjustmentDirection
  quantity               Int
  unitCostAtRequest      Decimal              @default(0) @db.Decimal(12, 2) // snapshot for value-threshold + shrinkage valuation
  reasonCode             AdjustmentReasonCode
  reasonNote             String?
  evidenceUrl            String?
  linkedReconciliationId String? // back-reference to Module 5 StockReconciliation
  status                 AdjustmentStatus     @default(PENDING_APPROVAL)
  requestedBy            String
  requestedAt            DateTime             @default(now())
  approvedBy             String?
  approvedAt             DateTime?
  rejectedReason         String?
  createdAt              DateTime             @default(now())

  @@unique([pharmacyId, adjustmentNumber])
  @@index([pharmacyId, branchId, medicineId])
  @@index([pharmacyId, status])
  @@index([reasonCode])
  @@index([linkedReconciliationId])
}
